# Photon Spectrum credentials from https://app.photon.codes
PROJECT_ID=
PROJECT_SECRET=

# Public URL for payment/proof pages. Localhost works only for local testing.
PUBLIC_APP_URL=http://127.0.0.1:5173

# Vercel AI SDK agent brain. DeepSeek is preferred when set.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_PUBLIC_DNS=true
RECEIPTS_AI_MODEL=deepseek-chat
RECEIPTS_AI_TIMEOUT_MS=45000
RECEIPTS_AI_MAX_RETRIES=5
RECEIPTS_ALLOW_LOCAL_PARSER_FALLBACK=false

# Optional fallback provider.
OPENAI_API_KEY=

# Receipt-photo OCR through Mistral.
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest

# Optional: use your own Mac Messages database while developing with Spectrum local mode.
IMESSAGE_LOCAL=false

# Keep off for ngrok/free shared-line testing because link previews look generic.
# Turn on when using a real domain/native iMessage app card.
IMESSAGE_NATIVE_CARDS=false

# Optional: show Spectrum's local terminal chat UI for debugging.
SPECTRUM_TERMINAL=false

# Optional: debug Spectrum logs.
SPECTRUM_LOG_LEVEL=info

# Local message API port.
PORT=8787

# Local SQLite database. Keep this as a file path for local dev.
REMY_DATABASE_URL=data/remy.sqlite
